{
  "name": "node-forge",
  "displayName": "NodeForge",
  "description": "Generate full Node.js/Express backends with one click — MongoDB, MySQL, PostgreSQL, TypeScript/JavaScript, JWT Auth",
  "publisher": "SahanCW",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "express",
    "nodejs",
    "mongodb",
    "backend",
    "scaffold",
    "generator",
    "crud",
    "rest api",
    "mongoose",
    "typescript",
    "javascript",
    "jwt",
    "authentication",
    "MySQL",
    "PostgreSQL"
  ],
  "icon": "Logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/WeerasingheMSC/First_Exetention.git"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nodeforge.generateMernModule",
        "title": "Generate Backend Module"
      },
      {
        "command": "nodeforge.generateAuth",
        "title": "Generate Auth Module"
      },
      {
        "command": "nodeforge.openSidebar",
        "title": "Open NodeForge"
      },
      {
        "command": "nodeforge.generateFullBackendFromSidebar",
        "title": "Generate Full Backend"
      },
      {
        "command": "nodeforge.addModuleToBackend",
        "title": "Add Module to Backend"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "backendGenerator",
          "title": "NodeForge",
          "icon": "images/nodeforge-icon.svg"
        }
      ]
    },
    "views": {
      "backendGenerator": [
        {
          "type": "webview",
          "id": "backendGeneratorSidebar",
          "name": "NodeForge",
          "icon": "images/nodeforge-icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}

{
  "name": "my-first-extension",
  "displayName": "my-first-extension",
  "description": "anything",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "my-first-extension.generateMernModule",
        "title": "Generate Backend Module"
      },
      {
        "command": "my-first-extension.generateAuth",
        "title": "Generate Auth Module"
      },
      {
        "command": "my-first-extension.openSidebar",
        "title": "Open Backend Generator"
      },
      {
        "command": "my-first-extension.generateFullBackendFromSidebar",
        "title": "Generate Full Backend"
      },
      {
        "command": "my-first-extension.addModuleToBackend",
        "title": "Add Module to Backend"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "backendGenerator",
          "title": "Backend Generator",
          "icon": "$(server-environment)"
        }
      ]
    },
    "views": {
      "backendGenerator": [
        {
          "type": "webview",
          "id": "backendGeneratorSidebar",
          "name": "Backend Generator",
          "icon": "$(server-environment)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "esbuild": "^0.27.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
